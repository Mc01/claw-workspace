# ============================================================
# ChamaFi Frontend — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# All variables MUST be prefixed with VITE_ to be accessible
# in the browser (Vite requirement).
#
# NEVER commit .env.local to version control.
# ============================================================

# ── WalletConnect ────────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── Contract Addresses ───────────────────────────────────────
# ChamaFactory address deployed on each network.
# These default to 0x0...0 if not set (no factory interaction).

# Celo Mainnet (chain 42220)
VITE_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Celo Alfajores / Sepolia (chain 44787)
VITE_FACTORY_ADDRESS_SEPOLIA=0x0000000000000000000000000000000000000000

# Local Anvil (chain 31337) — set after running `make deploy-local`
VITE_FACTORY_ADDRESS_LOCAL=0x0000000000000000000000000000000000000000
