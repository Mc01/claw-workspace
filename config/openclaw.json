{
    "gateway": {
        "bind": "lan",
        "auth": {
            "mode": "token"
        },
        "controlUi": {
            "allowedOrigins": [
                "https://vps-73da905b.tail73b9a1.ts.net"
            ]
        }
    },
    "session": {
        "dmScope": "per-channel-peer"
    },
    "tools": {
        "fs": {
            "workspaceOnly": true
        },
        "exec": {
            "security": "full"
        }
    },
    "models": {
        "mode": "merge",
        "providers": {
            "synthetic": {
                "baseUrl": "https://api.synthetic.new/anthropic",
                "apiKey": "${SYNTHETIC_API_KEY}",
                "api": "anthropic-messages",
                "models": [
                    {
                        "id": "kimi-k2.5",
                        "name": "Kimi K2.5"
                    },
                    {
                        "id": "glm-5",
                        "name": "GLM 5"
                    },
                    {
                        "id": "deepseek-r1",
                        "name": "DeepSeek R1"
                    },
                    {
                        "id": "deepseek-r1-distill-llama-8b",
                        "name": "DeepSeek Fast"
                    },
                    {
                        "id": "minimax-m2.1",
                        "name": "MiniMax"
                    },
                    {
                        "id": "qwen3.5",
                        "name": "Qwen Vision"
                    }
                ]
            }
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "synthetic/kimi-k2.5"
            }
        },
        "list": [
            {
                "id": "manager",
                "name": "Project Manager",
                "default": true,
                "subagents": {
                    "allowAgents": [
                        "architect",
                        "engineer",
                        "reviewer",
                        "researcher",
                        "ui-checker"
                    ]
                }
            },
            {
                "id": "architect",
                "name": "System Architect",
                "model": {
                    "primary": "synthetic/minimax-m2.1"
                }
            },
            {
                "id": "engineer",
                "name": "Software Engineer",
                "model": {
                    "primary": "synthetic/glm-5",
                    "fallbacks": [
                        "synthetic/kimi-k2.5"
                    ]
                }
            },
            {
                "id": "reviewer",
                "name": "Code Reviewer",
                "model": {
                    "primary": "synthetic/deepseek-r1"
                }
            },
            {
                "id": "researcher",
                "name": "Context Researcher",
                "model": {
                    "primary": "synthetic/deepseek-r1-distill-llama-8b"
                }
            },
            {
                "id": "ui-checker",
                "name": "UI/UX Specialist",
                "model": {
                    "primary": "synthetic/qwen3.5"
                }
            }
        ]
    }
}